# Copy this file to .env.local and fill in the values.
# NEVER put real values in this file — it gets committed to git. Real values go in .env.local only.

# --- MongoDB Atlas (free M0 cluster: https://www.mongodb.com/cloud/atlas) ---
# Database -> Connect -> Drivers -> copy the connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- Session signing secret ---
# Any long random string. Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=paste-a-long-random-string-here

# --- The teacher's email(s). Whoever logs in with one of these becomes the admin. ---
# Separate multiple emails with commas.
ADMIN_EMAILS=teacher@example.com

# --- SMTP for sending OTP emails (Brevo free tier: 300 emails/day) ---
# Brevo -> SMTP & API -> SMTP tab
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@example.com
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM_EMAIL=verified-sender@example.com
SMTP_FROM_NAME=Aptitude Exam Portal

# --- Optional: how long students stay signed in (days). Default 30. ---
# Longer = fewer OTP emails burned from the daily quota.
SESSION_DAYS=30

# --- Optional: fallback SMTP, used automatically if the primary fails ---
# (quota exhausted, IP blocked, outage). Example: Gmail with an app password
# (Google Account -> Security -> 2-Step Verification -> App passwords).
# SMTP2_HOST=smtp.gmail.com
# SMTP2_PORT=587
# SMTP2_USER=yourgmail@gmail.com
# SMTP2_PASS=your-16-char-app-password
